# Python bytecode
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# Secrets — never bake into the image
.env
.env.*
docker-compose*.yml

# Generated cache — re-created at runtime
cache/

# Demo and map data — bind-mounted, not baked into the image
mvd2/
bsp/
textures/
colormap.pcx

# Game assets — bind-mounted, not baked into the image
players/
models/

# SQLite database files
*.db
*.db-wal
*.db-shm

# Source trees and unrelated projects
source/
EPIC/
tests/
live-test/
docs/
stat-collection-main/
mvdtool-master/
q2pro-aqtion/
aq2-tng-aqtion/

# Dev / editor noise
.git/
*.md
*.stats
.vscode/
.DS_Store
