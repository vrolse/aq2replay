# Example environment variables for aq2replay
# Copy this file to .env and fill in your values / secrets.

# ── Flask & Gunicorn ─────────────────────────────────────────────────────────
FLASK_DEBUG=false
TZ=Europe/Stockholm
GUNICORN_WORKERS=1
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=180
GUNICORN_GRACEFUL_TIMEOUT=30

# ── Reverse proxy ─────────────────────────────────────────────────────────────
# Enable if sitting behind Nginx Proxy Manager or similar.
PROXY_FIX_ENABLED=false
PROXY_FIX_X_FOR=1
ENABLE_HSTS=false

# ── API security ──────────────────────────────────────────────────────────────
# Rate limiting
API_RATE_LIMIT_ENABLED=false
API_RATE_LIMIT_PER_MIN=240

# Optional bearer-token auth for admin endpoints.
# Set SCOPE=admin to protect only sensitive routes (recommended for public sites).
# Set SCOPE=all to require a token on every /api/* request.
API_BEARER_AUTH_ENABLED=false
API_BEARER_HEADER=X-Api-Bearer
API_BEARER_SCOPE=admin
API_BEARER_TOKEN=                   # generate with: openssl rand -base64 48

# Optional manual reindex API. Disabled by default; automatic indexing runs on
# startup and daily via watchdog.
STATS_REINDEX_API_ENABLED=false
STATS_REINDEX_API_TOKEN=            # generate with: openssl rand -base64 48

# ── Live GTV viewer ───────────────────────────────────────────────────────────
# Password used by the preset server buttons and the status widget.
LIVE_PRESET_PASSWORD=

# Anti-cheat delay for the live stream (seconds). 0 = no delay.
LIVE_STREAM_DELAY_SEC=60

# ── Database paths ────────────────────────────────────────────────────────────
STATS_DB_PATH=/var/lib/aq2replay/stats.db
STATS_DB_FALLBACK_PATH=/var/lib/aq2replay/stats_fallback.db

# ── SQLite performance tuning (KiB / MiB) ────────────────────────────────────
# Good defaults for a 4 vCPU / 24 GB ARM VPS. Reduce for smaller machines.
STATS_SQLITE_READ_CACHE_KB=131072
STATS_SQLITE_WRITE_CACHE_KB=65536
STATS_SQLITE_MMAP_MB=512
STATS_SQLITE_BUSY_TIMEOUT_MS=60000
STATS_SQLITE_TEMP_STORE=MEMORY

# ── Prewarm ───────────────────────────────────────────────────────────────────
# Scopes: off | standard | extended | full
STATS_PREWARM_SCOPE=extended
STATS_PREWARM_TOP_WEAPONS=24
STATS_PREWARM_TOP_PLAYERS=24
STATS_PREWARM_TOP_MAPS=16
STATS_PREWARM_TOP_H2H=12
STATS_PREWARM_INCLUDE_GEMINI=false

# ── Assets ───────────────────────────────────────────────────────────────────
# Remote server for textures, player models and weapon skins.
ASSET_BASE_URL=http://dlserver.aq2world.com/action/action

# ── AI insights (optional) ───────────────────────────────────────────────────
# Provider: heuristic (default, no API key needed) or gemini.
# Falls back to heuristic automatically on error / missing key.
AI_INSIGHTS_PROVIDER=heuristic
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TIMEOUT_SECONDS=12
GEMINI_API_KEY=                     # Google AI Studio key — keep secret
